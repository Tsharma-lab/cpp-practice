#include<iostream>
using namespace std;
int main()
{
    int num,temp,result=0,n;
    cout<<"enter a number:";
    cin>>num;
    temp=num;
    while(num!=0)
    {
        n=num%10;
        result=result*10+n;
        num=num/10;
    }
    if(result==temp)
    {
        cout<<"palindrome";
    }
    else
    {
        cout<<"not palindrome";
    }
    return 0;
}
