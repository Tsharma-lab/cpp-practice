#include<iostream>
#include<cmath>
using namespace std;
int max(int arr[],int n)
{
    int max;
    max=arr[0];
    for(int i=1;i<n;i++)
    {
        if(arr[i]>max)
        {
            max=arr[i];
        }
    }
    return max;
}
int main()
{
    int arr[20],n;
    cout<<"enter the size of array:";
    cin>>n;
    cout<<"enter the array:";
    for(int i=0;i<n;i++)
    {
        cin>>arr[i];
    }
    cout<<"max:"<<max(arr,n);
    return 0;
}
