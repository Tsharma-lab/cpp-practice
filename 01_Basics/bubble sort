#include<iostream>
#include<cmath>
using namespace std;
void swap(int *a,int* b)
{
    int temp=*a;
    *a=*b;
    *b=temp;
    
}
int main()
{
    int arr[20],n;
    cout<<"enter the size of array:";
    cin>>n;
    cout<<"enter the array:";
    for(int i=0;i<n;i++)
    {
        cin>>arr[i];
    }
    for(int i=0;i<n;i++)
    {
       for(int j=0;j<n-i-1;j++)
       {
           if(arr[j]>arr[j+1])       
           {
               swap(&arr[j],&arr[j+1]);
           }
       }
    }
    cout<<"Sorted array: ";

    for(int i=0;i<n;i++)
        cout<<arr[i]<<" ";

    return 0;
}
