#include<iostream>
#include<cmath>
using namespace std;
int main()
{
    int num,temp,result=0,n,digits=0;
    cout<<"enter a number:";
    cin>>num;
    temp=num;
    while(temp!=0)
    {
        digits++;
        temp=temp/10;
    }
    temp=num;
    while(temp!=0)
    {
        n=temp%10;
        result=result+ pow(n,digits);
        temp=temp/10;
    }
    if(result==num)
    {
        cout<<"armstrong";
    }
    else
    {
        cout<<"not armstrong";
    }
    return 0;
}
